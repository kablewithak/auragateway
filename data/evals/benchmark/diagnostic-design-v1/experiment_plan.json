  "hypotheses": [
    {
      "hypothesis_id": "h1_deterministic_request_defect",
      "statement": "A provider-visible request shape remains invalid regardless of local condition label, sequence position, or request spacing.",
      "supporting_pattern": "The same turn index is rejected consistently across matched cohorts, both local labels, both sequence positions, and both spacing cells.",
      "weakening_pattern": "Matched provider-visible requests succeed in one or more cohorts or the rejection moves between turns without a stable request-shape pattern."
    },
    {
      "hypothesis_id": "h2_first_sequence_state_effect",
      "statement": "The first sequence using a previously unseen stable prefix encounters a provider-side state transition that later sequences using that prefix do not encounter.",
      "supporting_pattern": "The first sequence in both order-reversal cohorts is rejected at the same turn regardless of whether condition B or condition C executes first, while the second sequence succeeds.",
      "weakening_pattern": "Rejections follow the local condition label rather than first position, occur in both positions, or do not reproduce across the two reversed cohorts."
    },
    {
      "hypothesis_id": "h3_spacing_sensitive_state",
      "statement": "Rapid repeated-prefix requests trigger a provider-side admission or prefix-state anomaly that is reduced when bounded spacing is introduced.",
      "supporting_pattern": "Zero-second spacing cells produce request rejection while matched thirty-second spacing cells for both local labels complete without request rejection.",
      "weakening_pattern": "Thirty-second cells fail at the same rate or location as zero-second cells, or failures track label or cohort identity instead of spacing."
    },
    {
      "hypothesis_id": "h4_condition_specific_harness_difference",
      "statement": "A hidden local condition-specific difference reaches the provider boundary despite the current evidence that conditions B and C are provider-visible equivalent.",
      "supporting_pattern": "Condition C sequences are rejected across first and second positions and across zero and thirty-second spacing, while matched condition B sequences succeed.",
      "weakening_pattern": "Failures follow first position, spacing, or random cohort identity rather than the local condition label."
    },
    {
      "hypothesis_id": "h5_transient_provider_backend",
      "statement": "The Batch 06 rejection was a transient provider, transport, or backend-routing event with no stable relationship to request shape, local condition, sequence position, or spacing.",
      "supporting_pattern": "Failures are isolated, non-repeating, or inconsistent across matched cells and do not form the predeclared deterministic, position, spacing, or condition-specific patterns.",
      "weakening_pattern": "A stable rejection pattern repeats across cohorts and aligns with one of the other predeclared explanatory variables."
    }
  ],
