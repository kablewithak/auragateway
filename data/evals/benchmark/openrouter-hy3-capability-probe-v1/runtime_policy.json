  "generation_metadata_polling_permitted": false,
  "successful_completion_requires_generation_metadata": true,
  "write_through_journal_required": true,
  "protected_raw_retention_required": true,
  "protected_parsed_retention_required": true,
  "public_raw_payload_permitted": false,
  "authorization_consumed_on_terminal_closeout": true,
  "resume_permitted": false,
  "rerun_permitted": false
